APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=notifications@serviceop.ca
MAIL_FROM_NAME=ServiceOP
MAIL_REPLY_TO=coerceair@outlook.com
RESEND_API_KEY=

# Twilio SMS (Milestone 3)
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SMS_ENABLED=false

# AI provider (Milestone 4) — mock | openai
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_TIMEOUT=20
# OPENAI_COST_PER_1M_INPUT=0.15
# OPENAI_COST_PER_1M_OUTPUT=0.60

# Gmail OAuth (leads inbox) — Option A. Tokens stored encrypted in DB, not here.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Local: http://127.0.0.1:8000/oauth/gmail/callback
# Prod:  https://api.serviceop.ca/oauth/gmail/callback
GOOGLE_REDIRECT_URI="${APP_URL}/oauth/gmail/callback"
GMAIL_MAILBOX=leads@serviceop.ca
GMAIL_FETCH_ENABLED=true
# GMAIL_POLL_QUERY="in:inbox newer_than:14d"
# GMAIL_MAX_RESULTS=25

# Payment provider: mock | stripe
PAYMENT_PROVIDER=mock
# Stripe (test mode first). Never commit real keys. Secret must NOT be exposed to frontend.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Connected-accounts Event Destination (same /api/stripe/webhook URL, different signing secret)
STRIPE_CONNECT_WEBHOOK_SECRET=
# STRIPE_CURRENCY=cad
# INVOICE_NUMBER_FORMAT=INV-{XXXX}
# PAYOUT_SCHEDULE_BUSINESS_DAYS=2

# Frontend URL for portal links in SMS/email
FRONTEND_URL=http://localhost:5173

# Public multi-tenant intake (Milestone 5)
# Brand rows live in DB (domain, theme, company_source_id). Local Host fallback:
# PUBLIC_LOCAL_DEFAULT_BRAND_DOMAIN=acuteradrywall.ca
# PUBLIC_INTAKE_SESSION_TTL_HOURS=48
# PUBLIC_EXTRA_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# AI_CONVERSATIONAL_PROVIDER=mock
# For real chat streaming locally: AI_CONVERSATIONAL_PROVIDER=openai + OPENAI_API_KEY
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# DigitalOcean Spaces (required for production file uploads on App Platform)
# FILESYSTEM_DISK=s3
# UPLOADS_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=tor1
# AWS_BUCKET=serviceop-storage
# AWS_ENDPOINT=https://tor1.digitaloceanspaces.com
# AWS_URL=https://serviceop-storage.tor1.digitaloceanspaces.com
# AWS_USE_PATH_STYLE_ENDPOINT=false
# Optional: mount a DO Volume and set STORAGE_PUBLIC_ROOT if not using Spaces
# STORAGE_PUBLIC_ROOT=/app/storage/app/public

VITE_APP_NAME="${APP_NAME}"

# Production (live server — adminhsop.alphaarraytechnologies.com)
# APP_URL=https://adminhsop.alphaarraytechnologies.com
# FRONTEND_URL=https://hsop.alphaarraytechnologies.com
# FILESYSTEM_DISK=public
# SANCTUM_STATEFUL_DOMAINS=hsop.alphaarraytechnologies.com,adminhsop.alphaarraytechnologies.com
# CORS_ALLOWED_ORIGINS=https://hsop.alphaarraytechnologies.com,https://adminhsop.alphaarraytechnologies.com
# DEPLOY_SECRET=your-strong-secret-here
