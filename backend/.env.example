APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=notifications@serviceop.ca
MAIL_FROM_NAME=ServiceOP
MAIL_REPLY_TO=coerceair@outlook.com
RESEND_API_KEY=

# Twilio SMS (Milestone 3)
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SMS_ENABLED=false

# Frontend URL for portal links in SMS/email
FRONTEND_URL=http://localhost:5173

# DigitalOcean Spaces (set FILESYSTEM_DISK=s3 when configured)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=nyc3
AWS_BUCKET=
AWS_ENDPOINT=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=true

VITE_APP_NAME="${APP_NAME}"

# Production (live server — adminhsop.alphaarraytechnologies.com)
# APP_URL=https://adminhsop.alphaarraytechnologies.com
# FRONTEND_URL=https://hsop.alphaarraytechnologies.com
# FILESYSTEM_DISK=public
# SANCTUM_STATEFUL_DOMAINS=hsop.alphaarraytechnologies.com,adminhsop.alphaarraytechnologies.com
# CORS_ALLOWED_ORIGINS=https://hsop.alphaarraytechnologies.com,https://adminhsop.alphaarraytechnologies.com
# DEPLOY_SECRET=your-strong-secret-here
